<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GeoPingApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GeoPingApp"
    xmlns:Views="clr-namespace:GeoPingApp.Views"
    Shell.NavBarIsVisible="False"
    Title="GeoPingApp">

    <ShellContent
        Title="Welcome"
        ContentTemplate="{DataTemplate Views:Welcome}"
        Route="welcome" />

    <TabBar Route="main">
        <ShellContent
            Title="Inicio"
            ContentTemplate="{DataTemplate Views:HomePage}"
            Route="homePage" />

        <ShellContent
            Title="Localização"
            ContentTemplate="{DataTemplate Views:LocationPage}"
            Route="locationPage" />

        <ShellContent
            Title="Perfil"
            ContentTemplate="{DataTemplate Views:Profile}"
            Route="profile" />        
    </TabBar>
</Shell>
