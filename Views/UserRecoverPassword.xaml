<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GeoPingApp.Views.UserRecoverPassword"
             Title="UserRecoverPassword">
    <Grid Padding="20" RowDefinitions="Auto, Auto, Auto, Auto, *">
        <Label
            Grid.Row="0"
            Text="GeoPing"
            VerticalOptions="Center" 
            HorizontalOptions="Center"  
            FontSize="32"
            Margin="60"/>

        <Label
            Grid.Row="1"
            Text="Informe o email da sua conta para recuperar sua senha"
            VerticalOptions="Center" 
            HorizontalOptions="Center"
            Margin="60"/>

        <Grid Grid.Row="2" RowDefinitions="Auto, Auto">
            <Label Grid.Row="0" Text="E-mail"/>
            <Entry Grid.Row="1" x:Name="user_email" Placeholder="vinicius@email.com"/>
        </Grid>

        <HorizontalStackLayout Grid.Row="3" HorizontalOptions="Center" Spacing="6" Margin="0, 10, 0, 0">
            <Button
            Text="Recuperar senha"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Padding="12, 0"
            Clicked="Button_Clicked_RecuperarSenha"/>

            <Button
            Text="Voltar"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Padding="12, 0"
            Clicked="Button_Clicked_Voltar"/>
        </HorizontalStackLayout>

        <Label 
            Grid.Row="4"
            Text="Develop by Vinicius Cassemira"
            HorizontalOptions="Center"
            VerticalOptions="End"
            Margin="10"/>
    </Grid>
</ContentPage>