<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GeoPingApp.Views.HomePage"
             Title="HomePage">
    <Grid Padding="20" RowDefinitions="Auto, auto, *">
        <Label 
            Grid.Row="0"
            Text="Bem vindo a tela inicial do GeoPing!"
            VerticalOptions="Center" 
            HorizontalOptions="Center"  
            FontSize="32"
            Margin="60"/>

        <Button 
            Grid.Row="1"
            Text="Ver usuários" 
            Clicked="Button_Clicked_VerUsuarios"
            VerticalOptions="Center" 
            HorizontalOptions="Center"
            Margin="0"/>

        <Label
            Grid.Row="2"
            Text="Develop by Vinicius Cassemira"
            HorizontalOptions="Center"
            VerticalOptions="End"
            Margin="10"/>
    </Grid>
</ContentPage>