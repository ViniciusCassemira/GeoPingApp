<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GeoPingApp.Views.Profile"
             Title="Profile">
    <Grid Padding="20" RowDefinitions="Auto, *" RowSpacing="20">
        <Label 
            Grid.Row="0"
            Text="Perfil"
            VerticalOptions="Center" 
            HorizontalOptions="Center"
            FontSize="20" />

        <Grid Grid.Row="1" RowSpacing="10" RowDefinitions="Auto, Auto, Auto">
                
            <Button Grid.Row="0" Text="Editar perfil" Clicked="Button_Clicked_EditarPerfil" HorizontalOptions="Center"/>        
            
            <Button Grid.Row="1" Text="WebHook (em breve)" Clicked="Button_Clicked_WebHook" HorizontalOptions="Center"/>

            <Button
                Grid.Row="2"
                Text="Encerrar sessão"
                VerticalOptions="End" 
                HorizontalOptions="Center" 
                Clicked="Button_Clicked_EncerrarSessao"/>
        </Grid>
    </Grid>
</ContentPage>